      "@id": "untp:quantity",
      "schema:rangeIncludes": {
        "@id": "untp:Measure"
      },
      "@type": [
        "rdf:Property",
        "owl:ObjectProperty"
      ],
      "schema:domainIncludes": [
        {
          "@id": "untp:EventProduct"
        }
      ],
      "rdfs:comment": [

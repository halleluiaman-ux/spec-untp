      "schema:rangeIncludes": {
        "@id": "untp:Link"
      },
      "@type": [
        "rdf:Property",
        "owl:ObjectProperty"
      ],
      "schema:domainIncludes": [
        {
          "@id": "untp:SensorData"
        }
      ],

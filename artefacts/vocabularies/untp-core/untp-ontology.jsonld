    },
    {
      "@id": "untp:CriterionStatus#active",
      "@type": "untp:CriterionStatus",
      "rdf:value": "active",
      "rdfs:label": "Active",
      "rdfs:comment": "The criterion is in active use."
    },
    {
      "@id": "untp:CriterionStatus#deprecated",
      "@type": "untp:CriterionStatus",
      "rdf:value": "deprecated",
      "rdfs:label": "Deprecated",
      "rdfs:comment": "The criterion is deprecated."
    },
    {

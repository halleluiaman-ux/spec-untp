      ],
      "rdfs:label": "facility"
    },
    {
      "@id": "untp:eventDate",
      "schema:rangeIncludes": {
        "@id": "xsd:datetime"
      },
      "@type": [
        "rdf:Property",
        "owl:DatatypeProperty"

        },
        {
          "@id": "untp:ModifyEvent"
        }
      ],
      "rdfs:comment": [
        "The date and time at which this lifecycle event occurs. use 00:00 for time if only a date is required.",
        "The date and time at which this lifecycle event occurs. use 00:00 for time if only a date is required.",
        "The date and time at which this lifecycle event occurs. use 00:00 for time if only a date is required.",
        "The date and time at which this lifecycle event occurs. use 00:00 for time if only a date is required."
      ],

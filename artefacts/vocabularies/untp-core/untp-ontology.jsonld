        "owl:ObjectProperty"
      ],
      "schema:domainIncludes": [
        {
          "@id": "untp:Dimension"
        }
      ],
      "rdfs:comment": [
        "The width of the product or packaging. eg {\"value\":150, \"unit\":\"MMT\"}"
      ],
      "rdfs:label": "width"
    },
    {
      "@id": "untp:height",

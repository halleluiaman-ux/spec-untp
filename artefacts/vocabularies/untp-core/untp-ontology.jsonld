        "rdf:Property",
        "owl:ObjectProperty"
      ],
      "schema:domainIncludes": [
        {
          "@id": "untp:Dimension"
        }
      ],
      "rdfs:comment": [
        "the weight of the product. EG {\"value\":10, \"unit\":\"KGM\"}"
      ],
      "rdfs:label": "weight"
    },
    {
      "@id": "untp:length",
      "schema:rangeIncludes": {
        "@id": "untp:Measure"
      },
      "@type": [
        "rdf:Property",
        "owl:ObjectProperty"
      ],
      "schema:domainIncludes": [
        {

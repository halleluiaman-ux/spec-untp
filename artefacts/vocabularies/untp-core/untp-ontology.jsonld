      },
      "@type": [
        "rdf:Property",
        "owl:ObjectProperty"
      ],
      "schema:domainIncludes": [
        {
          "@id": "untp:LifecycleEvent"
        },
        {
          "@id": "untp:MakeEvent"
        },
        {
          "@id": "untp:MoveEvent"
        },
        {
          "@id": "untp:ModifyEvent"
        }
      ],
      "rdfs:comment": [
        "A sensor data set associated with this lifecycle event.",
        "A sensor data set associated with this lifecycle event.",
        "A sensor data set associated with this lifecycle event.",
        "A sensor data set associated with this lifecycle event."
      ],
      "rdfs:label": "sensorData"
